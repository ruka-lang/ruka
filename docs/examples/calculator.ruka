let local add = (a, b) do a + b
let local sub = (a, b) do a - b
let local mul = (a, b) do a * b
let local div = (a, b) do a / b

let main = () do
    let x = 12
    let y = 4
    ruka.println("${x} + ${y} = ${add(x, y)}")
    ruka.println("${x} - ${y} = ${sub(x, y)}")
    ruka.println("${x} * ${y} = ${mul(x, y)}")
    ruka.println("${x} / ${y} = ${div(x, y)}")
end
