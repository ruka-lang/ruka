local ALPHA = 0.0001
local EPSILON = 0.000001

let gradientDescent = (df) do
	let step = (x) do ALPHA * df(x)

	let *x = 10.0
	let *steps = 0
	while df(x) >= EPSILON do
		x = x - step(x)
		steps = steps + 1
	end

	(x, steps)
end

let main = () do
	let df = (x) do 
		(4.0 * (x ** 3.0)) - 
		(9.0 * (x ** 2.0))	
	end
	let (minimum, steps) = gradientDescent(df)

	ruka.println("A minimum of ${minimum} found in ${steps} steps")
end
