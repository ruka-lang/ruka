exports[`tokenize: fixture snapshots > methods-and-statics.ruka 1`] = `"let ID(counter) = record { ID(count) : ID(int) } NL NL let ID(new) ( ID(counter) ) = ( ID(start) ) do . { ID(count) = ID(start) } NL let ID(zero) ( ID(counter) ) = . { ID(count) = NUM(0) } NL let ID(Doubled) ( ID(counter) ) = ( ID(n) ) do ID(n) * NUM(2) NL NL let ID(bump) ( self ) = ( ) do . { ID(count) = self . ID(count) + NUM(1) } NL let ID(bumpDouble) ( self ) = ( ) do . { ID(count) = self . ID(count) + ID(counter) . ID(Doubled) ( NUM(1) ) } NL NL let ID(main) = ( ) do NL let ID(a) = ID(counter) . ID(zero) NL let ID(b) = ID(counter) . ID(new) ( NUM(10) ) NL let ID(c) = ID(b) . ID(bump) ( ) NL let ID(d) = ID(c) . ID(bumpDouble) ( ) NL NL ID(ruka) . ID(println) ( STR("a=\${a.count}\\nb=\${b.count}\\nc=\${c.count}\\nd=\${d.count}") ) NL end NL EOF"`;

