exports[`tokenize: fixture snapshots > combat.ruka 1`] = `"let ID(Hit) = variant { ID(critical) : ID(int) , ID(normal) : ID(int) , ID(miss) } NL NL let ID(attack) = ( ID(power) , ID(accuracy) ) do NL let ID(score) = ID(power) + ID(accuracy) NL if ID(score) >= NUM(15) do . ID(critical) ( ID(score) * NUM(2) ) NL else if ID(score) >= NUM(6) do . ID(normal) ( ID(score) ) NL else . ID(miss) NL end NL NL let ID(report) = ( ID(hit) ) do NL match ID(hit) with NL ID(critical) ( ID(dmg) ) do STR("*** Critical hit for \${dmg} damage! ***") NL ID(normal) ( ID(dmg) ) do STR("Hit for \${dmg} damage.") NL ID(miss) do STR("Missed!") NL end NL end NL NL let ID(main) = ( ) do NL ID(ruka) . ID(println) ( STR("=== Battle Report ===\\n\\nIron Sword  (pow=8,  acc=6):  \${report(attack(8,  6))}\\nRusty Knife (pow=3,  acc=4):  \${report(attack(3,  4))}\\nGreat Axe   (pow=14, acc=1):  \${report(attack(14, 1))}\\nMagic Wand  (pow=10, acc=5):  \${report(attack(10, 5))}\\nBare Fists  (pow=1,  acc=2):  \${report(attack(1,  2))}") ) NL end NL EOF"`;

exports[`tokenize: fixture snapshots > destructuring.ruka 1`] = `"let ID(swap) = ( ID(a) , ID(b) ) do [ ID(int) , ID(int) ] . { ID(b) , ID(a) } NL NL let ID(minmax) = ( ID(a) , ID(b) ) -> [ ID(int) , ID(int) ] do NL if ID(a) < ID(b) do . { ID(a) , ID(b) } NL else . { ID(b) , ID(a) } NL end NL NL let ID(main) = ( ) do NL let { ID(x) , ID(y) } = ID(swap) ( NUM(3) , NUM(7) ) NL ID(ruka) . ID(println) ( STR("swap(3, 7) = \${x}, \${y}") ) NL NL let { ID(lo) , ID(hi) } = ID(minmax) ( NUM(10) , NUM(4) ) NL ID(ruka) . ID(println) ( STR("minmax(10, 4) = \${lo}, \${hi}") ) NL end NL EOF"`;

exports[`tokenize: fixture snapshots > fibonacci.ruka 1`] = `"let ID(fib) = ( ID(n) ) do NL ID(n) if ID(n) <= NUM(1) else ID(fib) ( ID(n) - NUM(1) ) + ID(fib) ( ID(n) - NUM(2) ) NL end NL NL let ID(main) = ( ) do NL let * ID(i) = NUM(0) NL while ID(i) <= NUM(10) do NL ID(ruka) . ID(println) ( STR("fib(\${i}) = \${fib(i)}") ) NL ID(i) = ID(i) + NUM(1) NL end NL end NL EOF"`;

exports[`tokenize: fixture snapshots > fizzbuzz.ruka 1`] = `"let ID(main) = ( ) do NL let * ID(i) = NUM(1) NL while ID(i) <= NUM(20) do NL if ID(i) % NUM(15) == NUM(0) do ID(ruka) . ID(println) ( STR("FizzBuzz") ) NL else if ID(i) % NUM(3) == NUM(0) do ID(ruka) . ID(println) ( STR("Fizz") ) NL else if ID(i) % NUM(5) == NUM(0) do ID(ruka) . ID(println) ( STR("Buzz") ) NL else ID(ruka) . ID(println) ( STR("\${i}") ) NL ID(i) = ID(i) + NUM(1) NL end NL end NL EOF"`;

