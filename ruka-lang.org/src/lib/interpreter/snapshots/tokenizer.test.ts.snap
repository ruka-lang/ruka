exports[`tokenize: fixture snapshots > arrays.ruka 1`] = `"let ID(main) = ( ) do NL let * ID(primes) = [ ID(int) ] . { NUM(2) , NUM(3) , NUM(5) , NUM(7) , NUM(11) } NL ID(ruka) . ID(println) ( STR("primes:  \${primes}") ) NL ID(ruka) . ID(println) ( STR("length:  \${primes.length()}") ) NL ID(ruka) . ID(println) ( STR("first:   \${primes[0]}") ) NL ID(ruka) . ID(println) ( STR("last:    \${primes[primes.length() - 1]}") ) NL NL ID(primes) . ID(append) ( NUM(13) ) NL ID(ruka) . ID(println) ( STR("after append(13): \${primes}") ) NL NL ID(primes) . ID(remove) ( NUM(0) ) NL ID(ruka) . ID(println) ( STR("after remove(0):  \${primes}") ) NL NL NL let * ID(sum) = NUM(0) NL for ID(p) in ID(primes) do ID(sum) = ID(sum) + ID(p) NL ID(ruka) . ID(println) ( STR("sum:     \${sum}") ) NL NL NL ID(ruka) . ID(println) ( STR("slice:   \${primes[1..4]}") ) NL end NL EOF"`;

