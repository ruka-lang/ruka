exports[`tokenize: fixture snapshots > projectile.ruka 1`] = `"let ID(Vec2) = record { ID(x) : ID(float) , ID(y) : ID(float) } NL NL let ID(add) = ( ID(a) , ID(b) ) do . { ID(x) = ID(a) . ID(x) + ID(b) . ID(x) , ID(y) = ID(a) . ID(y) + ID(b) . ID(y) } NL let ID(scale) = ( ID(v) , ID(s) ) do . { ID(x) = ID(v) . ID(x) * ID(s) , ID(y) = ID(v) . ID(y) * ID(s) } NL let ID(magnitude) = ( ID(v) ) do ID(ruka) . ID(sqrt) ( ID(v) . ID(x) * ID(v) . ID(x) + ID(v) . ID(y) * ID(v) . ID(y) ) NL let ID(round1) = ( ID(n) ) do ID(ruka) . ID(floor) ( ID(n) * NUM(10.0) ) / NUM(10.0) NL NL let ID(main) = ( ) do NL let ID(gravity) = . { ID(x) = NUM(0.0) , ID(y) = - NUM(9.8) } NL let * ID(pos) = . { ID(x) = NUM(0.0) , ID(y) = NUM(20.0) } NL let * ID(vel) = . { ID(x) = NUM(8.0) , ID(y) = NUM(12.0) } NL let ID(dt) = NUM(0.5) NL let * ID(t) = NUM(0.0) NL NL ID(ruka) . ID(println) ( STR("Projectile  v0=\${round1(magnitude(vel))} m/s") ) NL ID(ruka) . ID(println) ( STR("-----------------------------") ) NL NL while ID(pos) . ID(y) > NUM(0.0) do NL ID(vel) = ID(add) ( ID(vel) , ID(scale) ( ID(gravity) , ID(dt) ) ) NL ID(pos) = ID(add) ( ID(pos) , ID(scale) ( ID(vel) , ID(dt) ) ) NL ID(t) = ID(t) + ID(dt) NL NL if ID(pos) . ID(y) < NUM(0.0) do ID(pos) = . { ID(x) = ID(pos) . ID(x) , ID(y) = NUM(0.0) } NL NL ID(ruka) . ID(println) ( STR("t=\${round1(t)}s  x=\${round1(pos.x)}m  y=\${round1(pos.y)}m") ) NL end NL NL ID(ruka) . ID(println) ( STR("-----------------------------") ) NL ID(ruka) . ID(println) ( STR("Range: \${round1(pos.x)}m   Time: \${round1(t)}s") ) NL end NL EOF"`;

exports[`tokenize: fixture snapshots > range-match.ruka 1`] = `"let ID(grade) = ( ID(score) ) do NL match ID(score) with NL NUM(90) ..= NUM(100) do STR("A") NL NUM(80) ..= NUM(89) do STR("B") NL NUM(70) ..= NUM(79) do STR("C") NL NUM(60) ..= NUM(69) do STR("D") NL else STR("F") NL end NL end NL NL let ID(main) = ( ) do NL let ID(scores) = [ ID(int) ] . { NUM(95) , NUM(83) , NUM(71) , NUM(65) , NUM(42) } NL for ID(s) in ID(scores) do NL ID(ruka) . ID(println) ( STR("Score \${s}: \${grade(s)}") ) NL end NL end NL EOF"`;

